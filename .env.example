# =============================================================================
# OCPP 1.6J Charge Point Simulator – Configuration
# =============================================================================
# Copy to .env and fill in required values. Optional vars have sensible defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Required – CSMS connection
# -----------------------------------------------------------------------------
# Base WebSocket URL of the CSMS (Central System Management System).
# OCPP 1.6 convention: {base}/{chargePointId}
# Examples:
#   wss://localhost:8081/ocpp
#   ws://api:8081/ocpp   (when simulator runs in Docker, api = backend service)
CSMS_WS_URL=wss://localhost:8081/ocpp

# Charge point identifier. Used in WebSocket path and BootNotification.
CHARGE_POINT_ID=CP001

# -----------------------------------------------------------------------------
# Simulator behaviour
# -----------------------------------------------------------------------------
# Auto-connect to CSMS on startup. Set to "false" to connect manually via HTTP API.
AUTO_CONNECT=true

# -----------------------------------------------------------------------------
# Connector and charging
# -----------------------------------------------------------------------------
# Number of physical connectors (default: 2)
NUMBER_OF_CONNECTORS=2

# Charging speed in kW. Overridden when CHARGER_PROFILE is set (default: 7.4)
CHARGING_SPEED_KW=7.4

# Max session duration in seconds. 0 = no limit (default: 3600)
MAX_SESSION_DURATION_SEC=3600

# -----------------------------------------------------------------------------
# Charger profile
# -----------------------------------------------------------------------------
# Profile from profiles.json: slow_ac_7kw | fast_ac_22kw | rapid_dc_50kw | ultrarapid_dc_150kw
# Sets max power, meter interval, measurands, and BootNotification model.
# Can be changed at runtime via POST /set-profile/:profileName
CHARGER_PROFILE=slow_ac_7kw

# -----------------------------------------------------------------------------
# HTTP control API
# -----------------------------------------------------------------------------
# Port for the control API and status page. 0 = disabled (default: 3000)
# Endpoints: GET /, GET /status, GET /profiles, POST /connect, /disconnect,
# POST /plug-in, /plug-out, /start-session, /stop-session, /fault, /available,
# POST /set-profile/:profileName
TRIGGER_HTTP_PORT=3000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: debug | info | warn | error (default: info in dev, warn in production)
# All OCPP messages (sent and received) are logged with timestamps at info level.
LOG_LEVEL=info
